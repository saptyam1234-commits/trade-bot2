# ═══════════════════════════════════════════════════════
#  TradeSignal AI — SMC System v3.1
#  COST-OPTIMIZED: Gemini Primary + Claude Validator
# ═══════════════════════════════════════════════════════

# ── AI API Keys ──────────────────────────────────────────
# Gemini (PRIMARY — FREE) — https://aistudio.google.com/apikey
# Handles 90%+ of signals at zero cost
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Claude (VALIDATOR — Paid) — https://console.anthropic.com
# Only called when Gemini confidence >= 75% AND verdict = TAKE
# Saves ~90% of Claude API costs
CLAUDE_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── Data Sources ─────────────────────────────────────────
# Twelve Data — Forex + Gold (free 800 req/day)
# Get from: https://twelvedata.com/account/api-keys
TWELVE_DATA_KEY=YOUR_TWELVE_DATA_KEY_HERE
# Binance WebSocket — Crypto (NO KEY NEEDED)

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_TOKEN=123456789:ABCdefGHI_YOUR_BOT_TOKEN
TELEGRAM_CHANNEL=@your_channel_name

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
